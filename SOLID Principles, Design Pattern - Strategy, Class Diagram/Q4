interface Printer {
  print(): void;
}

interface Scanner {
  scan(): void;
}

interface Fax {
  fax(): void;
}

// Old printer (only print)
class OldPrinter implements Printer {
  print(): void {
    console.log("Printing...");
  }
}

// Smart printer (all features)
class SmartPrinter implements Printer, Scanner, Fax {
  print(): void {
    console.log("Printing...");
  }

  scan(): void {
    console.log("Scanning...");
  }

  fax(): void {
    console.log("Faxing...");
  }
}
