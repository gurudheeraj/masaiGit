class Engine {
  start(): void {
    console.log("Engine started");
  }
}

class Car {
  private engine: Engine;

  constructor() {
    this.engine = new Engine(); // tight coupling
  }

  drive(): void {
    this.engine.start();
    console.log("Car is driving");
  }
}

// Run
const car = new Car();
car.drive();
